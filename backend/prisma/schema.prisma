generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  client_portal
}

enum UserAuthType {
  password
  oauth_yandex
}

enum OAuthProvider {
  yandex
}

enum OwnerSubscriptionStatus {
  trial
  active
  expired
  canceled
}

enum AppointmentStatus {
  booked
  completed
  cancelled
  no_show
}

enum DiscountSourceType {
  manual
  feedback
}

enum RecommendationJobStatus {
  queued
  running
  succeeded
  failed
}

enum ReminderStatus {
  pending
  sent
  cancelled
}

enum ReminderRecipient {
  owner
  client
}

enum ClientPortalInvitePurpose {
  activation
  password_reset
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique
  passwordHash String?
  authType     UserAuthType @default(password)
  role         UserRole
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  oauthIdentities   OAuthIdentity[]
  ownerSubscription OwnerSubscription?
  ownerOrganization OwnerOrganization?
}

model OwnerOrganization {
  id          String   @id @default(uuid()) @db.Uuid
  ownerUserId String   @unique @db.Uuid
  fullName    String?
  phone       String?
  inn         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
}

model OAuthIdentity {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @db.Uuid
  provider       OAuthProvider
  providerUserId String
  providerEmail  String?
  rawProfile     Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model OwnerSubscription {
  id                 String                  @id @default(uuid()) @db.Uuid
  ownerUserId        String                  @unique @db.Uuid
  status             OwnerSubscriptionStatus
  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  user User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Client {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  name      String
  phone     String   @unique
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, phone])
}

model Category {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  categoryName String   @unique
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Service {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  categoryId String?  @db.Uuid
  name       String
  price      Decimal? @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([categoryId])
}

model Appointment {
  id                String            @id @default(uuid()) @db.Uuid
  userId            String            @db.Uuid
  clientName        String
  clientPhone       String
  categoryName      String
  serviceName       String
  serviceId         String?           @db.Uuid
  appointmentAt     DateTime?
  appointmentEnd    DateTime?
  status            AppointmentStatus
  amount            Decimal?          @db.Decimal(10, 2)
  serviceAmount     Decimal?          @db.Decimal(10, 2)
  extraAmount       Decimal?          @db.Decimal(10, 2)
  discountAmount    Decimal?          @db.Decimal(10, 2)
  appliedDiscountId String?           @db.Uuid
  notes             String?
  createdAt         DateTime          @default(now())

  @@index([userId])
  @@index([serviceId])
  @@unique([userId, appointmentAt, serviceName], map: "appointments_user_service_time_unique")
}

model DiscountRule {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  discountPercent Int
  isActive        Boolean
  createdAt       DateTime @default(now())

  @@index([userId])
}

model ClientDiscount {
  id                       String             @id @default(uuid()) @db.Uuid
  userId                   String             @db.Uuid
  clientPhone              String
  appointmentId            String?            @db.Uuid
  feedbackToken            String?
  discountPercent          Int
  sourceType               DiscountSourceType
  serviceId                String?            @db.Uuid
  serviceNameSnapshot      String?
  note                     String?
  expiresAt                DateTime?
  isUsed                   Boolean            @default(false)
  usedAt                   DateTime?
  usedOnAppointmentId      String?            @db.Uuid
  reservedAt               DateTime?
  reservedForAppointmentId String?            @db.Uuid
  createdAt                DateTime           @default(now())

  @@index([userId])
  @@index([clientPhone])
}

model FeedbackToken {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  appointmentId String?  @db.Uuid
  token         String   @unique
  expiresAt     DateTime
  isActive      Boolean  @default(true)
  usedAt        DateTime?
  createdAt     DateTime @default(now())

  @@index([userId])
}

model FeedbackResponse {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @db.Uuid
  feedbackText        String
  scoreResult         Int?
  scoreExplanation    Int?
  scoreComfort        Int?
  scoreBooking        Int?
  scoreRecommendation Int?
  periodBucket        DateTime @db.Date
  createdAt           DateTime @default(now())

  @@index([userId])
}

model RecommendationPrompt {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  name      String
  content   String
  isDefault Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model RecommendationJob {
  id           String                @id @default(uuid()) @db.Uuid
  userId       String                @db.Uuid
  promptId     String?               @db.Uuid
  resultId     String?               @db.Uuid
  periodType   String
  periodFrom   DateTime
  periodTo     DateTime
  status       RecommendationJobStatus
  requestedAt  DateTime              @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  durationMs   Int?
  promptChars  Int?
  sourceCount  Int?
  modelName    String?
  inputTokens  Int?
  outputTokens Int?
  errorCode    String?
  errorMessage String?

  @@index([userId])
}

model AiRecommendation {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @db.Uuid
  periodType         String
  periodFrom         DateTime @db.Date
  periodTo           DateTime @db.Date
  promptId           String?  @db.Uuid
  promptIdSnapshot   String?
  promptNameSnapshot String?
  promptSnapshot     String?
  summary            String
  sourceCount        Int
  modelName          String?
  inputTokens        Int?
  outputTokens       Int?
  createdAt          DateTime @default(now())

  @@index([userId])
}

model ClientPortalInvite {
  id          String                    @id @default(uuid()) @db.Uuid
  ownerUserId String                    @db.Uuid
  createdBy   String                    @db.Uuid
  clientPhone String
  tokenHash   String                    @unique
  purpose     ClientPortalInvitePurpose
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime                  @default(now())

  @@index([ownerUserId])
}

model ClientPortalProfile {
  authUserId                   String   @id @db.Uuid
  phone                        String   @unique
  displayName                  String?
  notificationsEnabled         Boolean  @default(false)
  /** Смещения напоминаний о записи для push клиенту (пусто = не слать клиенту) */
  clientReminderOffsetsMinutes Int[]    @default([])
  /** Окно тишины UTC «HH:mm», например 22:00 — не беспокоить с 22:00 до quietHoursEndUtc */
  quietHoursStartUtc           String?  @db.VarChar(5)
  quietHoursEndUtc             String?  @db.VarChar(5)
  lastLoginAt                  DateTime?
  createdAt                    DateTime @default(now())
}

model ClientPortalLink {
  id               String   @id @default(uuid()) @db.Uuid
  ownerUserId      String   @db.Uuid
  clientAuthUserId String   @db.Uuid
  clientId         String?  @db.Uuid
  clientPhone      String
  isActive         Boolean  @default(true)
  lastSeenAt       DateTime?
  createdAt        DateTime @default(now())

  @@unique([ownerUserId, clientPhone])
  @@unique([ownerUserId, clientAuthUserId], map: "idx_client_portal_links_owner_client_auth")
}

model PushSubscription {
  id          String   @id @default(uuid()) @db.Uuid
  ownerUserId String   @db.Uuid
  authUserId  String   @db.Uuid
  audience    String
  endpoint    String
  p256dh      String
  auth        String
  createdAt   DateTime @default(now())

  @@index([ownerUserId])
  @@unique([authUserId, ownerUserId, endpoint], map: "push_subscriptions_auth_user_id_owner_user_id_endpoint_key")
}

model OwnerNotificationSettings {
  userId                 String   @id @db.Uuid
  reminderOffsetsMinutes Int[]
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model AppointmentReminder {
  id              String             @id @default(uuid()) @db.Uuid
  appointmentId   String             @db.Uuid
  userId          String             @db.Uuid
  offsetMinutes   Int
  recipient       ReminderRecipient  @default(owner)
  remindAt        DateTime
  status          ReminderStatus
  sentAt          DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime           @default(now())

  @@unique([appointmentId, offsetMinutes, recipient])
  @@index([userId])
}
